# TikHub：解析 TikTok 分享链接，返回可播放视频 URL
TIKHUB_API_KEY=

# 语音转文字：OpenRouter Whisper-compatible 接口
OPENROUTER_API_KEY=
WHISPER_BASE_URL=https://openrouter.ai/api/v1
WHISPER_MODEL=openai/gpt-4o-mini-transcribe

# 字幕翻译 + 追问 AI：OpenAI-compatible Chat Completions
ANALYSIS_API_KEY=
ANALYSIS_BASE_URL=https://api.deepseek.com
ANALYSIS_MODEL=deepseek-v4-flash

# 视频分析 /api/analyze：独立 OpenAI-compatible Chat Completions
ANALYSIS_VIDEO_API_KEY=
ANALYSIS_VIDEO_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANALYSIS_VIDEO_MODEL=qwen3.7-plus

# 可选：本地/dev 固定公开视频 URL。配置后 /api/analyze 强制使用该视频，不下载 TikHub 视频
# 示例：https://help-static-aliyun-doc.aliyuncs.com/file-manage-files/zh-CN/20241115/cqqkru/1.mp4
ANALYSIS_TEST_VIDEO_URL=

# 可选：生产公网 origin。真实 TikHub 视频分析需要它生成 /api/tmp-video/:id?token=... 临时下载地址
PUBLIC_APP_URL=

# 可选：临时视频存储目录。不配置时默认 /tmp/tiktranslate-analysis-videos
ANALYSIS_TMP_VIDEO_DIR=/tmp/tiktranslate-analysis-videos

# 登录密码：用户在登录页输入该值
AUTH_TOKEN=

# JWT 签名密钥：至少 32 个字符
JWT_SECRET=

# 可选：在 URL 输入框输入 test1 时，/api/tikhub 返回这个固定测试视频
TEST1_VIDEO_URL=

# 可选：experiments/qwen-video-r2-demo/index.mjs 独立实验脚本使用
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_VIDEO_PUBLIC_URL=
QWEN_VIDEO_FPS=2
